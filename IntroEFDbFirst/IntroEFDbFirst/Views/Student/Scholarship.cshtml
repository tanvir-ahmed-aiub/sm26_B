@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<a href="/student/create">Create</a>
@if (Model.Count != 0)
{
    <table class="table table-bordered">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Address</th>
            <th>Cgpa</th>
            <th>Department</th>
            <th></th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Address</td>
                <td>@item.Cgpa</td>
                <td>@item.DeptId</td>
                <td>
                    <a target="_blank" class="btn btn-primary" href="/student/details/@item.Id">Details</a>
                    <a class="btn btn-success" href="/student/edit/@item.Id">Edit</a>
                    <a class="btn btn-danger" href="/student/delete/@item.Id">Delete</a>
                </td>
            </tr>
        }
    </table>

}
else
{
    <p>No data Found</p>
}